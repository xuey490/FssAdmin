APP_ENV=prod

# 生产环境必须为 false：开启后会回显异常堆栈/项目绝对路径等敏感信息
APP_DEBUG=false

APP_URL=http://localhost:8000

REFERER_CHECK_ENABLED=true

# 数据库配置
# ORM选择'thinkORM' or 'laravelORM'
ORM_DRIVER=laravelORM
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fssoa
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8
DB_PREFIX=sa_

# Session 相关配置
SESSION_STORAGE=redis  #redis_grouped
SESSION_TTL=3600
SESSION_GROUP_PREFIX=session:myapp

# Redis 连接配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# Cache设置
CACHE_DRIVER=redis

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# COOKIE设置
COOKIE_SECRET=your-actual-32-character-secret-here
COOKIE_DOMAIN=.yourdomain.com

##jwt设置
JWT_SINGLE_DEVICE_LOGIN=false   # 允许多设备
# JWT_SINGLE_DEVICE_LOGIN=true  # 单点登录

# 【必填】JWT 签名密钥，必须是 >=32 字节的随机强密钥，且每个环境唯一、严禁入库。
# 不设置或使用弱/默认值时框架会拒绝启动。生成示例：php -r "echo 'base64:'.base64_encode(random_bytes(48));"
JWT_SECRET=